---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { ABOUT } from "@consts";

const writings = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<PageLayout title={ABOUT.TITLE} description={ABOUT.DESCRIPTION}>
  <Container>
    <h4 class="animate font-semibold text-black dark:text-white">
      About
    </h4>
    <div class="space-y-16">
      <section>
        <article class="space-y-4">
          <p class="animate">
            This is a minimal portfolio and writing space: the same layout and
            theme as the home page, including light, dark, and system appearance
            from the footer controls.
          </p>
          <p class="animate">
            Browse
            <Link href="/blog">all posts</Link>
            or jump into the selected pieces below.
          </p>
        </article>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">Writings</h5>
          <Link href="/blog">See all posts</Link>
        </div>
        <ul class="flex flex-col gap-4">
          {
            writings.map((post) => (
              <li>
                <ArrowCard entry={post} />
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>
